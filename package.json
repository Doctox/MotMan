{
  "name": "entrelignes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "policy:runtime": "node scripts/build_runtime_catalog_policy.mjs",
    "predev": "npm run policy:runtime",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run policy:runtime",
    "build": "tsc -b && vite build",
    "postbuild": "npm run audit:security",
    "audit:security": "node scripts/check_production_secrets.mjs",
    "audit:pages": "node scripts/check_pages_artifact.mjs",
    "smoke:deployment": "node scripts/smoke_test_deployment.mjs",
    "test:unit": "vitest run",
    "test:e2e": "node scripts/reset_e2e_state.mjs && playwright test",
    "test:online": "node scripts/test_supabase_online.mjs",
    "test:priority0": "npm run test:unit && npm run test:e2e",
    "test:dimensions": "node scripts/test_grid_dimensions.mjs",
    "test:performance": "node scripts/check_runtime_budget.mjs",
    "test:ci": "npm run test:unit && npm run test:dimensions && npm run build && npm run test:performance && npm run audit:pages && npm run test:e2e",
    "audit:css": "node scripts/compact_css.mjs",
    "clean:css": "node scripts/compact_css.mjs --write",
    "preview": "vite preview --host 0.0.0.0",
    "mobile:sync": "npm run build && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:doctor": "cap doctor"
  },
  "dependencies": {
    "@capacitor/android": "7.6.8",
    "@capacitor/app": "7.1.2",
    "@capacitor/browser": "7.0.5",
    "@capacitor/core": "7.6.8",
    "@capacitor/ios": "7.6.8",
    "@fontsource-variable/dm-sans": "5.2.8",
    "@fontsource-variable/playfair-display": "5.2.8",
    "@supabase/supabase-js": "2.100.0",
    "better-sqlite3": "^11.10.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "7.6.8",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "4.3.4",
    "postcss": "^8.5.17",
    "typescript": "latest",
    "vite": "6.4.3",
    "vitest": "^4.1.10",
    "ws": "8.21.1"
  }
}
