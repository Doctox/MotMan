{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": [
    "server/**/*.ts",
    "vite.config.ts",
    "src/gridCatalogPolicy.ts",
    "src/gridDimensions.ts",
    "src/gameRules.ts",
    "src/botOpponents.ts",
    "src/playerNamePolicy.ts",
    "src/data/*.json"
  ]
}
